{
  "name": "betaflight-mcp",
  "version": "1.0.0",
  "description": "MCP server for Betaflight flight controllers via MSP protocol",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "betaflight-mcp": "dist/server.js"
  },
  "scripts": {
    "generate": "tsx scripts/generate-variables.ts",
    "prebuild": "pnpm run generate",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "author": "Bob Vandevliet",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.12.2",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "serialport": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
